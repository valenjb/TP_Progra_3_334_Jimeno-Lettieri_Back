<%- include("partials/head.ejs") %>
<%- include("partials/tema.ejs") %>
<main class="bienvenida">
    <section class="tarjeta-bienvenida">
        <h2><%= title %></h2>
        <p><%= about %></p>

        <form action="/login" method="POST" class="form-admin">
            <label for="emailUser">Email</label>
            <input type="email" name="email" id="emailUser" required>

            <label for="passwordUser">Contraseña</label>
            <input type="password" name="password" id="passwordUser" required>

            <button type="submit" class="boton-primario">Ingresar</button>

            <div class="contenedor-autocomp">
                <button type="button" id="btnAutofill" class="btn-autocomp">
                    <img src="/assets/img/varios/autocompletar.png" alt="autocompletar" class="links-login">
                </button>
            </div>  
        </form>

        <% if (typeof error !== "undefined") { %>
            <p class="mensaje mensaje-error"><%= error %></p>
        <% } %>
    </section>
</main>

<script>
    const btnAutofill = document.getElementById('btnAutofill');
    if (btnAutofill) {
        btnAutofill.addEventListener('click', () => {
            const emailInput = document.getElementById('emailUser');
            const passwordInput = document.getElementById('passwordUser');

            emailInput.value = 'admin@lvtech.com';
            passwordInput.value = '1234';
            
        });
    }
</script>

<%- include("partials/footer.ejs") %>